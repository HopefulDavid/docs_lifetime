{
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          ".github/**",
          "_site*/**",
          "node_modules/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/kitchen"
    ],
    "globalMetadata": {
      "_appName": "Dokumentace ze života",
      "_appTitle": "Život",
      "_enableSearch": true,
      "pdf": true
    }
  }
}
